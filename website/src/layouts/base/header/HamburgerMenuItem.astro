---
type Props = {
    href?: string;
    externalLink?: boolean;
    itemType: 'toplevel' | 'subitem';
    hasSeparatorAbove?: boolean;
};

const { href, externalLink, itemType, hasSeparatorAbove } = Astro.props;

const liClass = itemType === 'toplevel' ? 'text-xl font-bold ml-4 py-4' : 'text-md font-light ml-8 pt-2';
const separatorClass = hasSeparatorAbove ? 'mt-2 border-t border-gray-200' : '';
---

<li class={`${liClass} ${separatorClass}`}>
    {
        href === undefined ? (
            <slot />
        ) : (
            <a
                class={
                    externalLink === true
                        ? 'after:iconify after:mdi--external-link after:ml-0.5 after:align-text-bottom'
                        : ''
                }
                href={href}
            >
                <slot />
            </a>
        )
    }
</li>
